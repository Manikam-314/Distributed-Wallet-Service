# AI Service Environment Variables
APP_NAME=ai-service
ENVIRONMENT=development
LOG_LEVEL=INFO

# Feature Toggles
ENABLE_KAFKA=false
ENABLE_REDIS=false

# LLM Keys
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
LLM_PROVIDER=gemini # 'openai' or 'gemini'

# Models 
FRAUD_MODEL_PATH=ml_models/fraud_model.pkl
SPENDING_MODEL_PATH=ml_models/spending_model.pkl
CREDIT_MODEL_PATH=ml_models/credit_model.pkl

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_NOTIFICATIONS_TOPIC=notifications.events

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
APP_PORT=8095
